{
  "name": "@webeach/event-manager",
  "version": "1.0.0",
  "description": "EventManager is a library for simplifying event handling in JavaScript",
  "keywords": [
    "EventDispatcher",
    "addEventListener",
    "addListener",
    "dom-events",
    "emitter",
    "event-handling",
    "event-utilities",
    "events",
    "subscribe",
    "typescript"
  ],
  "homepage": "https://github.com/webeach/event-manager",
  "bugs": {
    "url": "https://github.com/webeach/event-manager/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ruslan Martynov",
    "email": "github@webea.ch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webeach/event-manager"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "browser": "./dist/browser/index.js",
  "types": "./dist/cjs/index.d.cts",
  "unpkg": "./dist/browser/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "release": "semantic-release",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@size-limit/file": "^11.2.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.6",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "semantic-release": "^24.2.9",
    "size-limit": "^11.2.0",
    "tsup": "^8",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "**/*.json": [
      "oxfmt"
    ]
  },
  "size-limit": [
    {
      "path": "./dist/browser/index.js",
      "limit": "1 KB"
    }
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": "^10"
  },
  "packageManager": "pnpm@10.7.1"
}
