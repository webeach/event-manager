{
  "plugins": ["typescript"],
  "rules": {
    "curly": ["error", "all"],
    "id-length": [
      "error",
      {
        "min": 2,
        "exceptions": ["c", "i", "j", "k", "n"],
        "properties": "never",
        "checkGeneric": false
      }
    ],
    "typescript/no-explicit-any": "off",
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ]
  },
  "ignorePatterns": ["dist"]
}
